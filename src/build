#!/usr/bin/env bash

set -e

cd "$(dirname "$0")"
root="$(git rev-parse --show-toplevel)"
jdir="$root/gem/javascripts"

echo 'Generating javascript files'

# 1. ESM Module (Native export from pagy.ts)
bun build ./pagy.ts --target=node --no-bundle --outfile=$jdir/pagy.mjs

# 2. Browser IIFE (via temporary shim)
# Create a temporary entry point that assigns the export to window
echo 'import Pagy from "../../src/pagy.ts"; window.Pagy = Pagy;' > $jdir/pagy-shim.ts

bun build $jdir/pagy-shim.ts --target=browser --minify --outfile=$jdir/pagy.min.js
bun build $jdir/pagy-shim.ts --target=browser --sourcemap=linked --outfile=$jdir/pagy.js

rm $jdir/pagy-shim.ts

# 3. Wand (Browser script)
bun build ./wand.ts --target=browser --no-bundle --outfile=$jdir/wand.js
